# Copier ce fichier en .env et renseigner chaque variable.
# Utilisé par docker-compose.prod.yml

# ─── Tag de l'image Docker ────────────────────────────────────────────────────
# Laisser "latest" ou préciser un tag de release (ex: 1.2.0)
TAG=latest

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=chouine
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=chouine
# Décommenter uniquement si la base est externe (ex : RDS, Supabase) :
# PGSSLMODE=require

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changeme_very_long_random_secret
JWT_EXPIRES_IN=7d

# ─── SMTP (contact@la-chouine.com) ────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@la-chouine.com
SMTP_PASS=changeme_smtp_password
SMTP_FROM="La Chouine <contact@la-chouine.com>"

# ─── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://la-chouine.com
