{
  "name": "la-chouine-backend",
  "version": "1.0.0",
  "description": "API REST pour la-chouine.com",
  "main": "src/server.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "start:docker-dev": "node src/db/migrate.js && node --watch src/server.js",
    "migrate": "node src/db/migrate.js",
    "lint": "eslint .",
    "test": "sh -c 'if [ -f .env.test ]; then set -a; . ./.env.test; set +a; fi; : \"${REDIS_URL:=redis://mock}\"; export REDIS_URL; node --test tests/*.test.js'"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.10",
    "pg": "^8.12.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-n": "^18.1.0",
    "globals": "^17.6.0",
    "ioredis-mock": "^8.13.1",
    "supertest": "^7.0.0"
  }
}
