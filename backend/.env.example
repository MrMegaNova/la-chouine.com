# Base de données PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/chouine

# Serveur
PORT=3000
NODE_ENV=development

# JWT — générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# SMTP — contact@la-chouine.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@la-chouine.com
SMTP_PASS=your_smtp_password
SMTP_FROM="La Chouine <contact@la-chouine.com>"

# URL du frontend (pour les liens dans les emails)
FRONTEND_URL=https://la-chouine.com

# Durée de validité du lien de vérification email (en ms)
VERIFY_TOKEN_TTL_MS=86400000
