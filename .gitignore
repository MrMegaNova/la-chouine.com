# ─── Dépendances ──────────────────────────────────────────────────────────────
node_modules/

# ─── Variables d'environnement ────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Build frontend ───────────────────────────────────────────────────────────
frontend/dist/
public/
