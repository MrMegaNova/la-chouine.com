!frontend/public/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ─── OS / IDE ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/
